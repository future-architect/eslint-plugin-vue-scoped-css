{
  "name": "eslint-plugin-vue-scoped-css",
  "version": "2.12.0",
  "description": "ESLint plugin for Scoped CSS in Vue.js",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "prebuild": "npm run -s clean",
    "build": "tsdown",
    "clean": "rimraf .nyc_output dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && eslint .",
    "eslint-fix": "eslint . --fix",
    "pretest": "npm run build",
    "test:base": "node --import @oxc-node/core/register ./node_modules/mocha/bin/mocha.js \"tests/**/*.ts\" --reporter dot --timeout 60000",
    "test:coverage": "c8 --reporter=lcov npm run test:base",
    "test": "npm run test:base",
    "test:debug": "node --import @oxc-node/core/register ./node_modules/mocha/bin/mocha.js \"tests/**/*.ts\" --reporter dot",
    "test:watch": "npm run test:base -- --watch",
    "update": "node --import @oxc-node/core/register ./tools/update.ts && npm run eslint-fix",
    "new": "node --import @oxc-node/core/register ./tools/new-rule.ts",
    "predocs:watch": "npm run build",
    "docs:watch": "node --experimental-strip-types ./node_modules/vitepress/bin/vitepress.js dev docs",
    "docs:build": "npm run build && node --experimental-strip-types ./node_modules/vitepress/bin/vitepress.js build docs",
    "docs:open-dist": "cd ./docs/.vitepress/dist && npx -y http-server --open http://localhost:8080/eslint-plugin-vue-scoped-css/",
    "preversion": "npm test && npm run update && git add .",
    "version": "npm run lint -- --fix && git add .",
    "version:ci": "npm run update && changeset version",
    "prerelease": "npm run build",
    "release": "changeset publish",
    "updatefixture": "cross-env UPDATE_FIXTURE=\"true\" npm run test:base"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/future-architect/eslint-plugin-vue-scoped-css.git"
  },
  "author": "Yosuke Ota",
  "funding": "https://github.com/sponsors/ota-meshi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/future-architect/eslint-plugin-vue-scoped-css/issues"
  },
  "homepage": "https://future-architect.github.io/eslint-plugin-vue-scoped-css/",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "vue",
    "style",
    "scoped",
    "css"
  ],
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.5",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@ota-meshi/eslint-plugin": "^0.20.0",
    "@ota-meshi/site-kit-eslint-editor-vue": "^0.2.1",
    "@oxc-node/core": "^0.0.35",
    "@svitejs/changesets-changelog-github-compact": "^1.1.0",
    "@types/estree": "^1.0.5",
    "@types/lodash": "^4.17.5",
    "@types/mocha": "^10.0.7",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "assert": "^2.1.0",
    "c8": "^11.0.0",
    "cross-env": "^10.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-eslint-plugin": "^6.1.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-json-schema-validator": "^6.0.0",
    "eslint-plugin-jsonc": "^3.0.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-node-dependencies": "^2.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vue-scoped-css": "^2.8.0",
    "eslint-plugin-yml": "^3.0.0",
    "espree": "^11.0.0",
    "events": "^3.3.0",
    "mocha": "^11.0.0",
    "pako": "^2.1.0",
    "prettier": "^3.1.0",
    "rimraf": "^6.0.0",
    "semver": "^7.3.2",
    "stylelint": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-stylus": "^1.0.0",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.56.1",
    "vite-plugin-eslint4b": "^0.7.0",
    "vitepress": "^1.6.3",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "@eslint-community/eslint-utils": "^4.4.0",
    "lodash": "^4.17.21",
    "postcss": "^8.4.31",
    "postcss-safe-parser": "^7.0.0",
    "postcss-selector-parser": "^7.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9.38.0",
    "postcss-scss": "^4.0.3",
    "postcss-styl": "^0.12.0",
    "vue-eslint-parser": ">=7.1.0"
  },
  "peerDependenciesMeta": {
    "postcss-scss": {
      "optional": true
    },
    "postcss-styl": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
